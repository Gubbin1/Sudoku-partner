SudokuButtons:

<MainScreen>:
    orientation: "vertical"
    Label:
        text: "top margin"
        size_hint: (1, .2)
    MiddleGrid:
    Label:
        size_hint: (1, .05)
    EntryLayout:
        size_hint: (1, .2)
    Label:
        size_hint: (1, .05)

<MiddleGrid@BoxLayout>:
    ExampleDokus:
        size_hint: (.2, 1)
    SudokuButtons:
    Label:
        size_hint: (.2, 1)

<ExampleDokus@BoxLayout>
    orientation: "vertical"
    Button:
        text: "Easy example"
        on_press: app.root.fill_example(self)
    Button:
        text: "Medium example"
        on_press: app.root.fill_example(self)
    Button:
        text: "Hard example"
        on_press: app.root.fill_example(self)
    Button:
        text: "Evil example"
        on_press: app.root.fill_example(self)

<SudokuButtons>:
    cols: 9

<OptionGrid>:
    cols: 5
    pos_hint: {'center_x': .5}
    size_hint: (None, None)
    size: self.minimum_size

<ToggleButton>:
    on_press: app.root.switch_active(self)

<EntryLayout>:
    Label:
        id: "possDisplay"
        text: "Select a cell."
        pos_hint: {'x': .05, 'y':.05}
        size_hint: (None, None)
        size: (dp(80), dp(40))
    OptionGrid:
    Button:
        text: "Get hint"
        size_hint: (None, None)
        size: (dp(80), dp(40))
        pos_hint: {'right':.95, 'y':.05}
        on_press: root.run_solver(self)
