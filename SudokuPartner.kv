SudokuButtons:

<MainScreen>:
    orientation: "vertical"
    Label:
        text: "top margin"
        size_hint: (1, .2)
    SudokuButtons:
        pos_hint: {"center_x": .5}
    Label:
        size_hint: (1, .05)
    EntryLayout:
    Label:
        size_hint: (1, .05)

<SudokuButtons>:
    cols: 9
    pos_hint: {'center_x': .5}
    size_hint: (None, None)
    size: self.minimum_size
    top: self.height

<OptionGrid>:
    cols: 5
    pos_hint: {'center_x': .5}
    size_hint: (None, None)
    size: self.minimum_size

<ToggleButton>:
    on_press: app.root.switch_active(self)

<EntryLayout>:
    Label:
        id: "possDisplay"
        text: "Select a cell."
        pos_hint: {'x': .05, 'y':.05}
        size_hint: (None, None)
        size: (dp(80), dp(40))
    OptionGrid:
    Button:
        text: "Get hint"
        size_hint: (None, None)
        size: (dp(80), dp(40))
        pos_hint: {'right':.95, 'y':.05}
        on_press: root.run_solver(self)
