MainScreen:

<MainScreen>:
    canvas.before:
        Rectangle:
            size: self.size
            source: 'images/bg_gradient.jpg'
    orientation: "vertical"
    Label:
        text: "top margin"
        size_hint: (1, .1)
    MiddleBit:
        ExampleDokus:
            size_hint: (.2, .2)
            orientation: "vertical"
            Button:
                text: "Easy example"
                on_press: app.root.fill_example(self)
            Button:
                text: "Medium example"
                on_press: app.root.fill_example(self)
            Button:
                text: "Hard example"
                on_press: app.root.fill_example(self)
            Button:
                text: "Evil example"
                on_press: app.root.fill_example(self)
        SudokuButtons:
            canvas.before:
                Color: 
                    rgba: 0, 0, 0, 1
                Rectangle:
                    size: self.width, self.width
                    pos: self.width/5.05, self.height / 2

            padding: 2, 2, 2, 2
            cols: 12


        Label:
            id: myMessage
            text: "Select a cell"
            size_hint: (.2, 1)
            pos_hint: {'right': .95}
    EntryLayout:
        size_hint: (1, .1)
    

<ExampleDokus@BoxLayout>


<OptionGrid>:
    cols: 5
    pos_hint: {'center_x': .5}
    size_hint: (None, None)
    size: self.minimum_size

<ToggleButton>:
    on_press: app.root.switch_active(self)
    size_hint_y: None
    height: self.width


<EntryLayout>:
    Label:
        id: possDisplay
        text: "Select a cell."
        pos_hint: {'x': .05, 'y':.05}
        size_hint: (None, None)
        size: (dp(80), dp(40))
    OptionGrid:
    BoxLayout:
        orientation: "vertical"
        pos_hint: {'x': .85}
        Button:
            id: startButton
            text: "Lock in puzzle"
            size_hint: (None, None)
            size: (dp(80), dp(40))
            on_press: root.run_solver(self)
        Button:
            id: reset
            text: "Reset"
            size_hint: (None, None)
            size: (dp(80), dp(40))
            on_press: root.reset(self)
        Button:
            text: "Solve puzzle"
            size_hint: (None, None)
            size: (dp(80), dp(40))
            on_press: root.solveAll(self)
